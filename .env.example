# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key for admin operations (webhooks, Edge Functions)
# WARNING: Never expose this key to the browser! Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App URL (used for auth redirect links)
NEXT_PUBLIC_APP_URL=https://your-app-domain.com

# Evolution API Configuration (server-side only — no NEXT_PUBLIC prefix)
EVOLUTION_API_URL=https://your-evolution-api-server.com
EVOLUTION_API_KEY=your-evolution-api-key

# FedaPay Configuration
FEDAPAY_SECRET_KEY=your-fedapay-secret-key
FEDAPAY_WEBHOOK_SECRET=your-fedapay-webhook-secret

# Encryption — used to encrypt sensitive DB fields (e.g. WhatsApp API keys)
# Must be at least 32 characters. Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=your-random-32-char-secret-here

# Shared secret for the /api/whatsapp/credentials endpoint (used by n8n)
# Generate with: openssl rand -base64 32
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret-here
